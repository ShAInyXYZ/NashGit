# NashGit environment configuration.
# Copy this file to ".env" and fill in your values before running:
#   cp .env.example .env
#   docker compose up -d

# --- Required on first run ---

# Admin password for the web UI. Only applied on the very first start (empty DB).
# If left blank, a random password is generated and printed once in the container logs.
# After first run, change the password from the Settings page in the UI.
NASHGIT_ADMIN_PASSWORD=changeme

# Secret used to sign admin session cookies (JWT). Use a long random string.
# Generate one with:  openssl rand -hex 32
NASHGIT_SECRET=

# --- Optional ---

# Admin username (default: admin)
NASHGIT_ADMIN_USERNAME=admin

# Public base URL used to build clone URLs shown in the UI.
# Set this to how clients reach the NAS, e.g. https://nas.local or http://192.168.1.50:3000
# If empty, clone URLs are built from the request host at runtime.
NASHGIT_PUBLIC_URL=

# Port exposed by the container (default: 3000)
PORT=3000
